# Load test configuration — copy to load-tests/.env and fill in values.
# Never commit load-tests/.env (gitignored via .env.* pattern).

# Target Next.js deployment
BASE_URL=

# Must match LOAD_TEST_SECRET on Vercel (only set during load test windows)
LOAD_TEST_SECRET=

# k6 profile: smoke | stress | cloud | cloud-geo
K6_PROFILE=

# Grafana k6 Cloud project ID (for K6_PROFILE=cloud or cloud-geo)
# K6_CLOUD_PROJECT_ID=

# cloud-geo profile tuning (honest sustained operating point across US/EU/AP)
# Grafana Cloud free/trial projects cap at 100 VUs — combined defaults: 25 readers + 75 stake max
# GEO_STAKE_RATE=45
# GEO_DURATION=5m
# GEO_READER_VUS=25
# GEO_VU_BUDGET=100
# GEO_STAKE_MAX_VUS=75

# Market read interval (seconds) — used by poll-read scenario
POLL_REFRESH_SECONDS=2

# Default stake amount for load-test writes (matches UI chip)
DEFAULT_STAKE_AMOUNT=50

# --- MQTT subscriber soak (load-tests/mqtt/) ---
AWS_REGION=
AWS_IOT_ENDPOINT=
COGNITO_IDENTITY_POOL_ID=
TELEMETRY_TOPIC=

# MQTT soak defaults (override via CLI flags)
# MQTT_CONNECTIONS=50
# MQTT_DURATION_SEC=60
